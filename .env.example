# Reames Agent — environment variables
# Copy this to .env and fill in your API keys.

# DeepSeek API key (required if using DeepSeek provider)
DEEPSEEK_API_KEY=sk-your-key-here

# Optional: stable token for `reames-agent serve` when [serve].auth_mode = "token"
# REAMES_AGENT_SERVE_TOKEN=change-this-long-random-token

# Optional: custom config directory
# REAMES_AGENT_HOME=~/.reames-agent

# Optional: language override (auto/zh/en)
# REAMES_AGENT_LANG=zh
