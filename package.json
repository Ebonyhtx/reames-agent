{
  "name": "reames-agent",
  "version": "0.1.0",
  "description": "Reames Agent private root workspace for legacy web/TUI assets and maintenance tooling.",
  "private": true,
  "workspaces": [
    "apps/*",
    "ui-tui",
    "ui-tui/packages/*",
    "web"
  ],
  "scripts": {
    "postinstall": "echo 'Reames Agent workspace ready. Use scripts/install.sh, scripts/install.ps1, or cmd/reames-agent for the Go runtime.'",
    "install:root": "npm install --workspaces=false",
    "install:web": "npm install --workspace web",
    "install:tui": "npm install --workspace ui-tui",
    "install:desktop": "npm install --workspace apps/desktop",
    "audit:root": "npm audit --workspaces=false",
    "audit:web": "npm audit --workspace web",
    "audit:tui": "npm audit --workspace ui-tui",
    "audit:fix:root": "npm audit fix --workspaces=false",
    "audit:fix:web": "npm audit fix --workspace web",
    "audit:fix:tui": "npm audit fix --workspace ui-tui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ebonyhtx/reames-agent.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Ebonyhtx/reames-agent/issues"
  },
  "homepage": "https://github.com/Ebonyhtx/reames-agent#readme",
  "dependencies": {
    "@streamdown/math": "^1.0.2",
    "agent-browser": "^0.26.0"
  },
  "overrides": {
    "lodash": "4.18.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
