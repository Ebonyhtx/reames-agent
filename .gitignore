# Ignore everything by default
/*

# But allow root-level files and dirs we need
!/.gitignore

# Agent core - our custom files
!/agent/entropy.py
!/agent/status_bar.py
!/agent/mermaid_offload.py
!/agent/deepseek_cache.py
!/agent/__init__.py

# Plugins - our custom plugins
!/plugins/
/plugins/*
!/plugins/reames_git/
!/plugins/reames_build/
!/plugins/reames_code_analysis/
!/plugins/reames_crawler/

# Hooks
!/hooks/
/hooks/*
!/hooks/*.py

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.key

# Temp
*.bak
*.orig
/tmp/
